            "liquid": "{% comment %} Sección Contraindicaciones con imagen popup {% endcomment %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<div class=\"contre-indications-wrapper\">\n  \n  <button \n    class=\"contre-indications-btn\" \n    onclick=\"openContraModal()\"\n    type=\"button\"\n  >\n    <span class=\"btn-text\">Contraindicaciones</span>\n    <span class=\"btn-arrow\">›</span>\n  </button>\n\n  <div \n    id=\"contraModal\" \n    class=\"contra-modal-overlay\" \n    onclick=\"closeContraModal(event)\"\n  >\n    <div class=\"contra-modal-content\">\n      \n      <button \n        class=\"contra-close-btn\" \n        onclick=\"closeContraModal()\"\n        type=\"button\"\n      >\n        ✕\n      </button>\n\n      <img \n        src=\"https://i.postimg.cc/xTRW4bm8/hf-20260521-152154-1da65458-37b3-4630-858b-dceb3368c9bf.png\"\n        alt=\"Contraindicaciones Erlona Drenaje Linfático\"\n        class=\"contra-image\"\n        loading=\"lazy\"\n      >\n\n    </div>\n  </div>\n\n</div>\n\n<style>\n  .contre-indications-wrapper {\n    margin: 16px 0;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .contre-indications-btn {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    background: #F5EFE0;\n    border: 1.5px solid #D2C498;\n    border-radius: 10px;\n    padding: 12px 18px;\n    cursor: pointer;\n    width: 100%;\n    text-align: left;\n    transition: all 0.2s ease;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .contre-indications-btn:hover {\n    background: #EDE5CC;\n    border-color: #264634;\n  }\n\n  .btn-text {\n    flex: 1;\n    font-size: 14px;\n    font-weight: 600;\n    color: #264634;\n    letter-spacing: 0.3px;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .btn-arrow {\n    font-size: 20px;\n    color: #264634;\n    font-weight: 300;\n    transition: transform 0.2s ease;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .contre-indications-btn:hover .btn-arrow {\n    transform: translateX(3px);\n  }\n\n  .contra-modal-overlay {\n    display: none;\n    position: fixed;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: rgba(0, 0, 0, 0.75);\n    z-index: 99999;\n    align-items: center;\n    justify-content: center;\n    padding: 20px;\n    box-sizing: border-box;\n    backdrop-filter: blur(4px);\n  }\n\n  .contra-modal-overlay.active {\n    display: flex;\n  }\n\n  .contra-modal-content {\n    position: relative;\n    max-width: 480px;\n    width: 100%;\n    border-radius: 16px;\n    overflow: hidden;\n    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4);\n    animation: modalSlideIn 0.3s ease;\n  }\n\n  @keyframes modalSlideIn {\n    from {\n      opacity: 0;\n      transform: translateY(20px) scale(0.95);\n    }\n    to {\n      opacity: 1;\n      transform: translateY(0) scale(1);\n    }\n  }\n\n  .contra-image {\n    width: 100%;\n    height: auto;\n    display: block;\n    border-radius: 16px;\n  }\n\n  .contra-close-btn {\n    position: absolute;\n    top: 12px;\n    right: 12px;\n    background: rgba(0, 0, 0, 0.6);\n    color: white;\n    border: none;\n    border-radius: 50%;\n    width: 32px;\n    height: 32px;\n    font-size: 14px;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    z-index: 10;\n    transition: background 0.2s;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .contra-close-btn:hover {\n    background: rgba(0, 0, 0, 0.85);\n  }\n\n  @media (max-width: 480px) {\n    .contra-modal-content {\n      max-width: 100%;\n      border-radius: 12px;\n    }\n\n    .btn-text {\n      font-size: 13px;\n    }\n  }\n</style>\n\n<script>\n  function openContraModal() {\n    const modal = document.getElementById('contraModal');\n    modal.classList.add('active');\n    document.body.style.overflow = 'hidden';\n  }\n\n  function closeContraModal(event) {\n    if (!event || event.target === document.getElementById('contraModal') || event.currentTarget.classList.contains('contra-close-btn')) {\n      const modal = document.getElementById('contraModal');\n      modal.classList.remove('active');\n      document.body.style.overflow = '';\n    }\n  }\n\n  document.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') {\n      closeContraModal();\n    }\n  });\n</script>"
